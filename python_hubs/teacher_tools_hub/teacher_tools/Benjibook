  const studentName = document.getElementById('student-name').value.trim();
  const bookTitle   = document.getElementById('book-title').value.trim();
  const charName    = document.getElementById('char-name').value.trim();
  const setting     = document.getElementById('setting').value.trim();
  const scale       = document.getElementById('conflict-scale').value;

  const err = document.getElementById('error-msg');

  if (!studentName) return showErr('What\'s your name? ✍️');
  if (!bookTitle)   return showErr('Give your book a title! 📖');
  if (!charName)    return showErr('Your character needs a name! 🦸');
  if (!setting)     return showErr('Where does your story happen? 🌍');
  if (!selectedGenre) return showErr('Pick a story world! (the emojis above)');
  if (!selectedTone)  return showErr('Pick a vibe color! 🎨');

  err.style.display = 'none';

  const key = `${selectedGenre}-${selectedTone}`;
  const toneConf = toneConfig[selectedTone];

  // Set CSS tone variables
  document.documentElement.style.setProperty('--tone-accent', toneConf.accent);
  document.documentElement.style.setProperty('--tone-bg', toneConf.bg);
  document.documentElement.style.setProperty('--tone-dark', toneConf.dark);

  // Get story (written or placeholder)
  let rawPages = STORIES[key] || placeholderStory(selectedGenre, selectedTone);

  // Apply intensity opener to page 1
  const opener = intensityOpeners[scale] || intensityOpeners[3];

  pages = rawPages.map((ch, idx) => {
    let text = ch.text;
    // Inject intensity opener as first line of chapter 1
    if (idx === 0) text = opener + '\n\n' + text;
    // Replace tokens
    text = text.replace(/\{char\}/g, charName).replace(/\{setting\}/g, setting);
    const title = ch.title.replace(/\{char\}/g, charName).replace(/\{setting\}/g, setting);
    return { ...ch, title, text };
  });

  // Set book header
  document.getElementById('book-badge').textContent =
    `${genreEmoji[selectedGenre]} ${genreLabel[selectedGenre]} · ${toneConf.label}`;
  document.getElementById('book-title-display').textContent = bookTitle;
  document.getElementById('book-author-display').textContent = studentName;

  // Build nav dots
  const dotsEl = document.getElementById('nav-dots');
  dotsEl.innerHTML = pages.map((_, i) =>
    `<div class="nav-dot${i===0?' active':''}" onclick="goToPage(${i})"></div>`
  ).join('');

  currentPage = 0;
  renderPage(0);
  showScreen('book-screen');
}

function renderPage(idx) {
  const ch = pages[idx];
  const paras = ch.text.split('\n').filter(p => p.trim());
  const parasHtml = paras.map((p, i) => {
    const safe = p.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    return i === 0 ? `<p class="drop-cap">${safe}</p>` : `<p>${safe}</p>`;
  }).join('');

  const isPlaceholder = ch.placeholder;

  document.getElementById('page-container').innerHTML = `
    <div class="page-card">
      <div class="page-meta">
        <span class="chapter-tag">Chapter ${idx+1} of 8</span>
        <span class="page-num">${idx+1} / 8</span>
      </div>
      <h2 class="chapter-title">${ch.title.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')}</h2>
      <div class="chapter-body">${parasHtml}</div>
      <div class="chapter-footer">
        <span>#readabook</span>
        <span>Mr. Benji's L.E.A.Ders Studio</span>
      </div>
      ${isPlaceholder ? '<div class="placeholder-banner">🛠 Placeholder — Mr. Benji can swap in a story here!</div>' : ''}
    </div>`;

  // Progress bar
  document.getElementById('progress-fill').style.width = `${((idx+1)/8)*100}%`;

  // Nav buttons
  document.getElementById('prev-btn').disabled = idx === 0;
  document.getElementById('next-btn').disabled = idx === pages.length - 1;

  // Dots
  document.querySelectorAll('.nav-dot').forEach((d, i) => {
    d.classList.toggle('active', i === idx);
  });

  currentPage = idx;
}

function navigate(dir) {
  const next = currentPage + dir;
  if (next >= 0 && next < pages.length) renderPage(next);
}

function goToPage(idx) { renderPage(idx); }

function showErr(msg) {
  const el = document.getElementById('error-msg');
  el.textContent = msg;
  el.style.display = 'block';
}

function showScreen(id) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  window.scrollTo(0, 0);
}

// Keyboard nav
document.addEventListener('keydown', e => {
  if (document.getElementById('book-screen').classList.contains('active')) {
    if (e.key === 'ArrowRight') navigate(1);
    if (e.key === 'ArrowLeft') navigate(-1);
  }
});
</script>
</body>
</html>
